{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "NyxScript",
  "scopeName": "source.nyxscript",
  "patterns": [
    { "include": "#python-block" },
    { "include": "#comments" },
    { "include": "#docstring" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#function-def" },
    { "include": "#keywords" },
    { "include": "#ui-functions" },
    { "include": "#socket-functions" },
    { "include": "#modules" },
    { "include": "#builtin-functions" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#braces" }
  ],
  "repository": {
    "python-block": {
      "begin": "^(\\s*)(python)(\\s*:\\s*)$",
      "beginCaptures": {
        "2": { "name": "keyword.control.nyxscript" }
      },
      "end": "^(\\s*)(end)(\\s*)$",
      "endCaptures": {
        "2": { "name": "keyword.control.nyxscript" }
      },
      "contentName": "meta.embedded.block.python",
      "patterns": [
        { "include": "source.python" }
      ]
    },
    "comments": {
      "patterns": [
        {
          "match": "#.*$",
          "name": "comment.line.number-sign.nyxscript"
        }
      ]
    },
    "docstring": {
      "comment": "A line whose entire content is a string literal — by convention the first statement in a `func` body.",
      "match": "^(\\s*)(\"(?:[^\"\\\\]|\\\\.)*\"|'(?:[^'\\\\]|\\\\.)*')(\\s*)$",
      "captures": {
        "2": { "name": "comment.block.documentation.nyxscript" }
      }
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.raw.nyxscript",
          "comment": "r\"...\" — no escapes recognized, no {expr} interpolation.",
          "begin": "r\"",
          "end": "\"",
          "patterns": [
            { "match": "\\\\\"", "name": "constant.character.escape.nyxscript" }
          ]
        },
        {
          "name": "string.quoted.single.raw.nyxscript",
          "begin": "r'",
          "end": "'",
          "patterns": [
            { "match": "\\\\'", "name": "constant.character.escape.nyxscript" }
          ]
        },
        {
          "name": "string.quoted.double.nyxscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.nyxscript", "match": "\\\\." },
            { "match": "\\{\\{|\\}\\}", "name": "constant.character.escape.nyxscript" },
            {
              "name": "meta.interpolation.nyxscript",
              "begin": "\\{",
              "beginCaptures": { "0": { "name": "punctuation.definition.interpolation.begin.nyxscript" } },
              "end": "\\}",
              "endCaptures": { "0": { "name": "punctuation.definition.interpolation.end.nyxscript" } },
              "patterns": [
                { "include": "#numbers" },
                { "include": "#booleans" },
                { "include": "#keywords" },
                { "include": "#ui-functions" },
                { "include": "#builtin-functions" },
                { "include": "#function-call" },
                { "include": "#operators" },
                { "match": "[A-Za-z_][A-Za-z0-9_]*", "name": "variable.other.nyxscript" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.nyxscript",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.nyxscript", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "match": "\\b\\d+(\\.\\d+)?\\b",
      "name": "constant.numeric.nyxscript"
    },
    "booleans": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.nyxscript"
    },
    "keywords": {
      "match": "\\b(set|if|else|end|foreach|while|break|continue|func|return|import|try|except|lambda|in|run|as|to|save|print|sleep|assert|fail|pip|pyblock|unsafe|and|or|not)\\b",
      "name": "keyword.control.nyxscript"
    },
    "function-def": {
      "match": "\\b(func)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
      "captures": {
        "1": { "name": "keyword.control.nyxscript" },
        "2": { "name": "entity.name.function.nyxscript" }
      }
    },
    "modules": {
      "match": "\\b(audit|dns|tls|http|network\\.discover|network\\.scan|recon)\\b",
      "name": "support.function.nyxscript"
    },
    "ui-functions": {
      "match": "\\b(ui)\\.(confirm|input|select|table|banner|status)\\b",
      "name": "support.function.builtin.nyxscript"
    },
    "socket-functions": {
      "match": "\\b(socket)\\.(connect_tls|connect|send|recv_text|recv|raw_send|raw_recv|raw_read|close)\\b",
      "name": "support.function.builtin.nyxscript"
    },
    "builtin-functions": {
      "match": "\\b(len|range|upper|lower|strip|split|join|contains|str|int|float|abs|round|sorted|reversed|min|max|sum|type_of|keys|values|items|get|replace|starts_with|ends_with|find|zip|parse_json|to_json|map|filter|sort_by|reduce|now|to_iso8601|sha256|md5|base64_encode|base64_decode|random|bytes_from_hex|bytes_to_hex|bytes_from_string|bytes_to_string|pack_uint16|pack_uint32|unpack_uint16|unpack_uint32|checksum|build_ip_header|build_tcp_header|build_udp_header|build_icmp_echo|regex_match|regex_find_all|regex_find|regex_replace)\\b(?=\\s*\\()",
      "name": "support.function.builtin.nyxscript"
    },
    "function-call": {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*)\\b(?=\\s*\\()",
      "name": "entity.name.function.nyxscript"
    },
    "operators": {
      "match": "(==|!=|<=|>=|<|>|=|\\+|-|\\*|/)",
      "name": "keyword.operator.nyxscript"
    },
    "braces": {
      "match": "[{}]",
      "name": "punctuation.definition.dict.nyxscript"
    }
  }
}
